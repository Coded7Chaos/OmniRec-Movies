# Copy to .env and edit as needed. The defaults in core/settings.py already
# point to the artefacts produced by notebooks 02 and 03.

DEBUG=True
SECRET_KEY=django-insecure-replace-me-in-production
ALLOWED_HOSTS=*

# Absolute paths. Defaults resolve to <repo>/models y <repo>/data/intermediate.
# OMNIREC_MODELS_DIR=/absolute/path/to/OmniRec-Movies/models
# OMNIREC_DATA_DIR=/absolute/path/to/OmniRec-Movies/data/intermediate

# If True, loads SVD/NMF/Baseline at server startup; KNN stays lazy regardless (305 MB).
OMNIREC_EAGER_LOAD=False
