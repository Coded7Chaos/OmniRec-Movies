# Copia este archivo a .env y edita lo necesario. Los defaults en core/settings.py
# ya apuntan a los artefactos producidos por los notebooks 02 y 03.

DEBUG=True
SECRET_KEY=django-insecure-replace-me-in-production
ALLOWED_HOSTS=*

# Rutas absolutas. Por defecto resuelven a <repo>/models y <repo>/data/intermediate.
# OMNIREC_MODELS_DIR=/absolute/path/to/OmniRec-Movies/models
# OMNIREC_DATA_DIR=/absolute/path/to/OmniRec-Movies/data/intermediate

# Si es True, carga SVD/NMF/Baseline al arrancar; KNN queda lazy siempre (305 MB).
OMNIREC_EAGER_LOAD=False

# True = usa el dev-server de Vite en http://localhost:5173 (npm run dev).
# False = sirve los assets compilados desde frontend/dist (npm run build).
DJANGO_VITE_DEV_MODE=False
DATABASE_URL=mysql://root@127.0.0.1:3306/omnirec_movies
