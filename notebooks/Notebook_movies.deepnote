        - id: 9108f1e2ced44c37bed43c13ce948be2
          blockGroup: fe8b0a42-345a-4522-a3ee-93ac6af3533a
          sortingKey: "000049"
          executionCount: 97
          type: code
          content: >-
            import numpy as np

            from sklearn.model_selection import RandomizedSearchCV, cross_validate

            from sklearn.metrics import mean_absolute_error


            # 1. Definición de la grilla de parámetros

            param_distributions = {
                "LinearRegression": {},
                "Ridge": {
                    'regressor__alpha': np.logspace(-3, 3, 10)
                },
                "RandomForestRegressor": {
                    'regressor__n_estimators': [100, 200, 300],
                    'regressor__max_depth': [None, 10, 20],
                    'regressor__min_samples_split': [2, 5, 10]
                },
                "XGBRegressor": {
                    'regressor__n_estimators': [100, 200],
                    'regressor__learning_rate': [0.01, 0.1, 0.2],
                    'regressor__max_depth': [3, 5, 7]
                }
            }


            # 2. Función de evaluación con RandomizedSearchCV modificada para incluir MAE

            def optimizar_y_evaluar(pipeline, nombre_modelo, X, y, params):
                print(f"--- Optimizando {nombre_modelo} ---")

                # Configurar la búsqueda aleatoria
                # Nota: Si params está vacío (como en LinearRegression), RandomizedSearchCV
                # ajustará el modelo base directamente sin buscar combinaciones.
                search = RandomizedSearchCV(
                    pipeline,
                    param_distributions=params,
                    n_iter=10 if params else 1, # Prevención de error si la grilla está vacía
                    cv=3,
                    scoring='neg_root_mean_squared_error', # La optimización se guía por RMSE
                    verbose=1,
                    random_state=42,
                    n_jobs=-1
                )

                # Entrenar la búsqueda
                search.fit(X, y)
                best_pipeline = search.best_estimator_

                # Evaluación cruzada final con el mejor modelo encontrado
                scores = cross_validate(
                    best_pipeline, X, y, cv=5,
                    # Añadimos 'neg_mean_absolute_error' aquí
                    scoring=('neg_root_mean_squared_error', 'neg_mean_absolute_error', 'r2')
                )

                # Extraemos e invertimos los errores
                rmse = -scores['test_neg_root_mean_squared_error'].mean()
                mae = -scores['test_neg_mean_absolute_error'].mean()
                r2 = scores['test_r2'].mean()

                print(f"Mejores Parámetros: {search.best_params_}")
                print(f"RMSE Promedio: {rmse:.4f}")
                print(f"MAE Promedio:  {mae:.4f}") # <--- MAE impreso
                print(f"R2 Promedio:   {r2:.4f}\n")

                # Devolvemos 4 valores
                return best_pipeline, rmse, mae, r2

            # 3. Ejecución (Actualizada para recibir 4 valores)

            print("FASE 4: OPTIMIZACIÓN Y EVALUACIÓN CRUZADA\n")


            # Para Linear Regression (sin tuning)

            modelo_lr, rmse_lr, mae_lr, r2_lr = optimizar_y_evaluar(pipeline_lr, "Linear", X_train, y_train,
            param_distributions["LinearRegression"])


            # Para los demás con Tuning

            modelo_ridge, rmse_ridge, mae_ridge, r2_ridge = optimizar_y_evaluar(pipeline_ridge, "Ridge", X_train,
            y_train, param_distributions["Ridge"])

            modelo_rf, rmse_rf, mae_rf, r2_rf = optimizar_y_evaluar(pipeline_rf, "Random Forest", X_train, y_train,
            param_distributions["RandomForestRegressor"])

            modelo_xgb, rmse_xgb, mae_xgb, r2_xgb = optimizar_y_evaluar(pipeline_xgb, "XGBoost", X_train, y_train,
            param_distributions["XGBRegressor"])
          metadata:
