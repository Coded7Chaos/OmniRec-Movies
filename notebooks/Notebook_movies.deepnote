        - id: d72e80f9ba434b4f906af07e4dcc6e7f
          blockGroup: 115a79f8-95e7-49a5-b49a-972290ff82c3
          sortingKey: "000058"
          executionCount: 101
          type: code
          content: >-
            from sklearn.model_selection import RandomizedSearchCV

            from sklearn.metrics import classification_report


            # 1. Definición de los Espacios de Búsqueda (Grids)

            param_dist_log = {
                'classifier__C': np.logspace(-3, 3, 7),
                'classifier__solver': ['liblinear', 'lbfgs']
            }


            param_dist_rf = {
                'classifier__n_estimators': [100, 200, 500],
                'classifier__max_depth': [None, 10, 20, 30],
                'classifier__min_samples_split': [2, 5, 10],
                'classifier__class_weight': ['balanced', None]
            }


            # 2. Función para optimizar y evaluar

            def optimizar_clasificador(pipeline, params, name, X, y):
                print(f"--- Optimizando {name} ---")
                search = RandomizedSearchCV(
                    pipeline,
                    param_distributions=params,
                    n_iter=10,
                    cv=5,
                    scoring='f1', # Optimizamos F1-Score para balancear precisión y sensibilidad
                    random_state=42,
                    n_jobs=-1
                )
                search.fit(X, y)
                print(f"Mejores parámetros: {search.best_params_}")
                return search.best_estimator_

            # 3. Ejecución de la optimización

            best_log = optimizar_clasificador(pipeline_log, param_dist_log, "Logística", X_train_clf, y_train_clf)

            best_rf = optimizar_clasificador(pipeline_rf_clf, param_dist_rf, "Random Forest", X_train_clf, y_train_clf)


            # 4. Evaluación Final en el set de TEST

            y_pred_log = best_log.predict(X_test_clf)

            y_pred_rf = best_rf.predict(X_test_clf)


            print("\nREPORTE FINAL RANDOM FOREST OPTIMIZADO:")

            print(classification_report(y_test_clf, y_pred_rf))
