            {roc_auc_rf:.4f}\n")


            # 6. Matrices de Confusión

            fig, axes = plt.subplots(1, 2, figsize=(12, 5))

            fig.suptitle('Matrices de Confusión: Baseline vs Random Forest', fontsize=14)


