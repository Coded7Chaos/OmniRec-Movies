        - id: e820e272272b447388acff010294dc2d
          blockGroup: d2d29fcb-4b1d-460f-9420-e3f26b78bc7c
          sortingKey: "000045"
          executionCount: 95
          type: code
          content: >-
            from sklearn.linear_model import LinearRegression, Ridge

            from sklearn.ensemble import RandomForestRegressor

            from xgboost import XGBRegressor

            from sklearn.model_selection import cross_validate, LearningCurveDisplay


            # 1. Definición de los pipelines (Lineal, Ridge, Random Forest y XGBoost)

            pipeline_lr = Pipeline(steps=[('preprocessor', preprocessor), ('regressor', LinearRegression())])

            pipeline_ridge = Pipeline(steps=[('preprocessor', preprocessor), ('regressor', Ridge(alpha=10.0))])

            pipeline_rf = Pipeline(steps=[('preprocessor', preprocessor), ('regressor',
            RandomForestRegressor(n_estimators=100, random_state=42))])

            pipeline_xgb = Pipeline(steps=[
                ('preprocessor', preprocessor),
                ('regressor', XGBRegressor(n_estimators=100, random_state=42))
            ])


            # 2. Función de evaluación modificada para extraer métricas para graficar

            def evaluar_modelo_reg(pipeline, nombre_modelo, X, y):
                # Añadimos 'neg_mean_absolute_error' al scoring
                metrics = {
                    'rmse': 'neg_root_mean_squared_error',
                    'mae': 'neg_mean_absolute_error',
                    'r2': 'test_r2' # cross_validate acepta 'r2' directamente
                }

                scores = cross_validate(pipeline, X, y, cv=5,
                                        scoring=('neg_root_mean_squared_error', 'neg_mean_absolute_error', 'r2'),
                                        return_estimator=True)

                # Scikit-learn devuelve los errores como negativos para maximizarlos, los invertimos
                rmse = -scores['test_neg_root_mean_squared_error'].mean()
                mae = -scores['test_neg_mean_absolute_error'].mean()
                r2 = scores['test_r2'].mean()

                print(f"--- {nombre_modelo} ---")
                print(f"RMSE Promedio: {rmse:.4f}")
                print(f"MAE Promedio:  {mae:.4f}") # <--- Nueva línea
                print(f"R2 Promedio:   {r2:.4f}\n")

                return scores['estimator'][0].named_steps['regressor'], rmse, mae, r2

            # 3. Ejecución (Actualizada para recibir 4 valores)

            print("FASE 4: EVALUACIÓN CRUZADA DE MODELOS DE REGRESIÓN\n")

            modelo_lr, rmse_lr, mae_lr, r2_lr = evaluar_modelo_reg(pipeline_lr, "Regresión Lineal (Baseline)", X_train,
            y_train)

            modelo_ridge, rmse_ridge, mae_ridge, r2_ridge = evaluar_modelo_reg(pipeline_ridge, "Regresión Ridge
            (Regularizado)", X_train, y_train)

            modelo_rf, rmse_rf, mae_rf, r2_rf = evaluar_modelo_reg(pipeline_rf, "Random Forest (Avanzado)", X_train,
            y_train)

            modelo_xgb, rmse_xgb, mae_xgb, r2_xgb = evaluar_modelo_reg(pipeline_xgb, "XGBoost (Estado del Arte)",
            X_train, y_train)
