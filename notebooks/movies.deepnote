        - id: 078976b483424810ab04ec7184112c22
          blockGroup: 13777b08-0529-4724-89fa-586b16f8018c
          sortingKey: "000059"
          executionCount: 102
          type: code
          content: >-
            from sklearn.metrics import roc_auc_score, f1_score, confusion_matrix, ConfusionMatrixDisplay


            # 5. Evaluación (F1-Score y ROC-AUC) usando los modelos OPTIMIZADOS

            # Usamos predict_proba para las probabilidades y predict para las clases

            prob_log = best_log.predict_proba(X_test_clf)[:, 1]

            prob_rf = best_rf.predict_proba(X_test_clf)[:, 1]


            roc_auc_log = roc_auc_score(y_test_clf, prob_log)

            roc_auc_rf = roc_auc_score(y_test_clf, prob_rf)


            f1_log = f1_score(y_test_clf, y_pred_log)

            f1_rf = f1_score(y_test_clf, y_pred_rf)


            print("--- COMPARACIÓN DE MODELOS DE CLASIFICACIÓN OPTIMIZADOS ---")

            print(f"Regresión Logística -> F1-Score: {f1_log:.4f} | ROC-AUC: {roc_auc_log:.4f}")

            print(f"Random Forest       -> F1-Score: {f1_rf:.4f} | ROC-AUC: {roc_auc_rf:.4f}\n")


            # 6. Matrices de Confusión Profesionales

            fig, axes = plt.subplots(1, 2, figsize=(14, 6))

            fig.suptitle('Matrices de Confusión: Modelos con Hiperparámetros Optimizados', fontsize=16,
            fontweight='bold')


            # Configuración visual para las matrices

            modelos_info = [
                (y_test_clf, y_pred_log, 'Regresión Logística (Tuned)', 'Blues', axes[0]),
                (y_test_clf, y_pred_rf, 'Random Forest (Tuned)', 'Greens', axes[1])
            ]


            for y_true, y_pred, title, color, ax in modelos_info:
                cm = confusion_matrix(y_true, y_pred)
                disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=['No Eficiente', 'Eficiente'])
                disp.plot(ax=ax, cmap=color, colorbar=False, values_format='d')
                ax.set_title(title, fontsize=13, pad=10)
                ax.grid(False)

            plt.tight_layout(rect=[0, 0.03, 1, 0.95])

            plt.show()
