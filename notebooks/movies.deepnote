            # 1. Análisis Bivariado: Scatter plots (Variables Continuas vs Target)

            fig, axes = plt.subplots(1, 2, figsize=(14, 6))

            fig.suptitle('Relación entre Variables Continuas y Heating Load', fontsize=16)


